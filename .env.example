# ===== ОСНОВНАЯ КОНФИГУРАЦИЯ =====
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here-min-32-characters-long
LOG_LEVEL=INFO

# ===== URL И СОКЕТЫ =====
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
WEBSOCKET_URL=ws://localhost:8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://127.0.0.1:3000"]

# ===== TELEGRAM (ДЛЯ БЭКАПА) =====
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ===== ИИ МОДЕЛИ =====
LLM_MODEL=meta-llama/Llama-2-13b-chat-hf
HUGGINGFACE_TOKEN=your-huggingface-token-here
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2:13b

# ===== ОБЛАЧНЫЕ СЕРВИСЫ =====
ORACLE_CLOUD_USER=your-oracle-email@example.com
ORACLE_CLOUD_PASS=your-oracle-password

GOOGLE_CLOUD_KEY_FILE=/app/secrets/google-key.json
GOOGLE_PROJECT_ID=your-google-project-id

AWS_ACCESS_KEY_ID=your-aws-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

AZURE_SUBSCRIPTION_ID=your-azure-sub-id
AZURE_TENANT_ID=your-azure-tenant-id

# ===== ХРАНИЛИЩА (S3-СОВМЕСТИМЫЕ) =====
BACKBLAZE_APP_KEY_ID=your-backblaze-key-id
BACKBLAZE_APP_KEY=your-backblaze-app-key
BACKBLAZE_BUCKET=pikman-ai

CLOUDFLARE_R2_TOKEN=your-cloudflare-r2-token
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_BUCKET=pikman-ai-backup

# ===== БД И КЭШИРОВАНИЕ =====
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

POSTGRES_URL=postgresql://user:password@localhost:5432/pikman_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pikman_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===== БЕЗОПАСНОСТЬ =====
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_EXPIRATION=86400
BCRYPT_ROUNDS=12

# ===== ЛИМИТЫ И ОГРАНИЧЕНИЯ =====
MAX_MESSAGE_LENGTH=5000
MAX_FILE_SIZE_MB=100
RATE_LIMIT_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_AGENTS=5

# ===== ФУНКЦИИ =====
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_PHONE_CONTROL=true
ENABLE_BROWSER=true
ENABLE_CONSOLE=true
ENABLE_FILE_MANAGER=true
ENABLE_SELF_IMPROVE=true
ENABLE_TELEGRAM_BACKUP=true

# ===== РЕЖИМЫ =====
DEBUG_MODE=false
TEST_MODE=false
DEMO_MODE=false
